<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="clr-namespace:ShadUI">

    <ControlTheme x:Key="{x:Type shadui:MarqueeTextBlock}"
                  TargetType="shadui:MarqueeTextBlock">
        <Setter Property="Template">
            <ControlTemplate TargetType="shadui:MarqueeTextBlock">
                <!-- ClipToBounds здесь — единственный механизм обрезки -->
                <Border ClipToBounds="True"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Canvas x:Name="PART_Canvas"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <TextBlock x:Name="PART_Text" />
                    </Canvas>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>